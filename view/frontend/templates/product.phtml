<script type="text/x-magento-init">
{
    "*": {
        "Magento_Ui/js/core/app": {
            "components": {
                "featured-product-stock": {
                    "component": "Miyabara_FeaturedProduct/js/view/stock",
                    "config": {
                        "template": "Miyabara_FeaturedProduct/stock",
                        "refreshUrl": "<?= $escaper->escapeJs($viewModel->getStockRefreshUrl()) ?>",
                        "refreshInterval": <?= (int) $viewModel->getRefreshInterval() ?>
                    }
                }
            }
        }
    }
}
